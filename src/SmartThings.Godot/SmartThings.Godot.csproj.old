<Project Sdk="Godot.NET.Sdk/4.6.0">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>SmartThings.Godot</RootNamespace>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Description>
      Godot 4.5 backend implementation for SmartThings abstraction layer.
      Contains all engine-specific code: rendering, input, audio, accessibility, networking.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SmartThings.Abstraction\SmartThings.Abstraction.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.*" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="8.*" />
    <PackageReference Include="MQTTnet" Version="4.*" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.*" />
    <!-- Chickensoft ecosystem for idiomatic Godot C# -->
    <PackageReference Include="Chickensoft.AutoInject" Version="2.*" />
    <PackageReference Include="Chickensoft.LogicBlocks" Version="5.*" />
  </ItemGroup>
</Project>
